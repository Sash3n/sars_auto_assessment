rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user data: readable and writable only by the authenticated owner.
    // Sensitive content is additionally encrypted client-side before write,
    // so these documents only ever hold ciphertext envelopes.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reference collections, if ever mirrored from repo config, are
    // world-readable and never client-writable. The source of truth for
    // tax tables and SARS codes stays in version-controlled code.
    match /reference/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
